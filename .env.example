# Copy this file to .env.local for local development

# Base URL of Envoy/Nginx gRPC-Web proxy (without trailing slash)
VITE_API_BASE_URL=http://localhost:8080

# App environment: development | staging | production
VITE_APP_ENV=development

# Access token TTL in milliseconds (for interceptor - matches backend)
VITE_ACCESS_TOKEN_TTL_MS=900000

# Mock mode – bypasses the real backend with in-memory data.
# Set to 'false' (or remove) once the backend is running.
VITE_MOCK_MODE=false
