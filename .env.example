# Copy this file to .env.local for local development

# Sa Vite dev serverom: relativni /api koristi proxy iz vite.config.ts.
VITE_API_BASE_URL=/api

# user-service HTTP (login, /client/..., /permissions) — podrazumevano :8080
# Docker (EXBanka-2-Infrastructure): obično host 8082 → VITE_USER_HTTP_URL=http://127.0.0.1:8082
VITE_USER_HTTP_URL=http://127.0.0.1:8080

# bank-service HTTP (trading, računi) — podrazumevano :8082 pri lokalnom go run
# Docker: obično host 8083 → VITE_BANK_HTTP_URL=http://127.0.0.1:8083
VITE_BANK_HTTP_URL=http://127.0.0.1:8082

# Alternativa: jedan Envoy/Nginx umesto Vite proxy-ja
# VITE_API_BASE_URL=http://localhost:8080

# App environment: development | staging | production
VITE_APP_ENV=development

# Access token TTL in milliseconds (for interceptor - matches backend)
VITE_ACCESS_TOKEN_TTL_MS=900000

# Mock mode – bypasses the real backend with in-memory data.
# Set to 'false' (or remove) once the backend is running.
VITE_MOCK_MODE=false
